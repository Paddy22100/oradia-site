# Configuration ORADIA Server
NODE_ENV=development
PORT=3001

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/oradia

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email Configuration (Brevo/SendGrid)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=ORADIA <contact@oradia.com>

# Configuration Cal.com
CAL_WEBHOOK_SECRET=your-cal-webhook-secret

# Configuration Analytics
ANALYTICS_ENABLED=true
TRACKING_CONVERSIONS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
