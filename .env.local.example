# Copie ce fichier en .env.local pour le dev local
# Ne jamais versionner les vraies clés

# Supabase (obligatoire pour /api/preorders/progress et /api/waitlist)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optionnel (fallback si SUPABASE_URL absent)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Objectif de précommande (optionnel, défaut 500)
PREORDER_GOAL=500
