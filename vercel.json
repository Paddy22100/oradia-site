{
  "version": 2,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/api/stripe-webhook",
      "dest": "/api/stripe-webhook.js"
    },
    {
      "src": "/api/admin/login",
      "dest": "/api/admin/login.js"
    },
    {
      "src": "/api/admin/logout",
      "dest": "/api/admin/logout.js"
    },
    {
      "src": "/api/admin/me",
      "dest": "/api/admin/me.js"
    },
    {
      "src": "/api/admin/data",
      "dest": "/api/admin/data.js"
    },
    {
      "src": "/api/admin/contacts-export",
      "dest": "/api/admin/contacts-export.js"
    },
    {
      "src": "/api/preorders/progress",
      "dest": "/api/preorders/progress.js"
    },
    {
      "src": "/api/create-checkout-session",
      "dest": "/api/create-checkout-session.js"
    },
    {
      "src": "/api/contact",
      "dest": "/api/contact.js"
    }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/admin/login.js": {
      "maxDuration": 10
    },
    "api/admin/logout.js": {
      "maxDuration": 10
    },
    "api/admin/me.js": {
      "maxDuration": 10
    },
    "api/admin/data.js": {
      "maxDuration": 30
    },
    "api/admin/contacts-export.js": {
      "maxDuration": 30
    },
    "api/preorders/progress.js": {
      "maxDuration": 10
    },
    "api/create-checkout-session.js": {
      "maxDuration": 30
    },
    "api/contact.js": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://fonts.googleapis.com https://api.stripe.com https://m.stripe.com; frame-src 'self' https://js.stripe.com https://m.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
