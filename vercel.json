{
  "version": 2,
  "crons": [
    {
      "path": "/api/fenetre/close",
      "schedule": "0 8 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/api/stripe-webhook",
      "dest": "/api/stripe-webhook.js"
    },
    {
      "src": "/api/payments/webhook",
      "dest": "/server/app.js"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/admin/index.js"
    },
    {
      "src": "/api/create-checkout-session",
      "dest": "/api/create-checkout-session.js"
    },
    {
      "src": "/api/preorders/progress",
      "dest": "/api/preorders/progress.js"
    },
    {
      "src": "/api/waitlist",
      "dest": "/api/waitlist.js"
    },
    {
      "src": "/api/mondial-relay/pickup-points",
      "dest": "/api/admin/index.js"
    },
    {
      "src": "/api/auth/(login|forgot-password|check-subscription|consume-tore-draw)(.*)",
      "dest": "/api/auth/index.js"
    },
    {
      "src": "/api/analyse-tirage",
      "dest": "/api/analyse-tirage.js"
    },
    {
      "src": "/api/fenetre/(.*)",
      "dest": "/api/fenetre/index.js"
    },
    {
      "src": "/api/support",
      "dest": "/api/support.js"
    }
  ],
  "functions": {
    "server/app.js": {
      "maxDuration": 30
    },
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/admin/index.js": {
      "maxDuration": 30
    },
    "api/create-checkout-session.js": {
      "maxDuration": 30
    },
    "api/preorders/progress.js": {
      "maxDuration": 10
    },
    "api/waitlist.js": {
      "maxDuration": 10
    },
    "api/auth/index.js": {
      "maxDuration": 15
    },
    "api/analyse-tirage.js": {
      "maxDuration": 30
    },
    "api/fenetre/index.js": {
      "maxDuration": 15
    },
    "api/support.js": {
      "maxDuration": 10
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://js.stripe.com https://api.brevo.com https://cdnjs.cloudflare.com https://vercel.live https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://fonts.googleapis.com https://api.stripe.com https://m.stripe.com https://api.brevo.com https://vercel.live wss://vercel.live https://bwvlpgklnhcwkdpabiwd.supabase.co https://nxxetkdozynuytlbhxdx.supabase.co https://api.quantumnumbers.anu.edu.au; frame-src 'self' https://js.stripe.com https://m.stripe.com https://vercel.live; object-src 'none'; base-uri 'self'; form-action 'self' https://checkout.stripe.com; upgrade-insecure-requests"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    }
  ]
}