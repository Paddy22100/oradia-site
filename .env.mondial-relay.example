# ===========================================
# ORADIA - Variables d'environnement requises
# ===========================================

# --- Base de données Supabase ---
# URL de votre projet Supabase
SUPABASE_URL=https://your-project.supabase.co
# Clé de service (rôles admin) - NE PAS EXPOSER CÔTÉ CLIENT
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Clé publique (pour le client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe ---
# Clé secrète (serveur uniquement)
STRIPE_SECRET_KEY=sk_live_...
# Clé publique (client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Secret webhook pour la synchronisation des paiements
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Mondial Relay API 1 (Recherche points relais) ---
# URL de l'API Mondial Relay
MONDIAL_RELAY_API1_URL=https://api.mondialrelay.com/WebService/WebService.asmx
# Code enseigne Mondial Relay
MONDIAL_RELAY_ENSEIGNE=YOUR_ENSEIGNE_CODE
# Clé privée API 1
MONDIAL_RELAY_PRIVATE_KEY=your-private-key-api1
# Marque/brand pour l'API
MONDIAL_RELAY_BRAND=BDTEST  # ou BDLIVE pour production

# --- Mondial Relay API 2 (Création expéditions) ---
# Login pour l'API 2
MONDIAL_RELAY_API2_LOGIN=your-api2-login
# Mot de passe pour l'API 2
MONDIAL_RELAY_API2_PASSWORD=your-api2-password
# URL de l'API 2 (même que API 1 généralement)
MONDIAL_RELAY_API2_URL=https://api.mondialrelay.com/WebService/WebService.asmx

# --- Authentification Admin ---
# Email administrateur du dashboard
ADMIN_EMAIL=contact@oradia.fr
# Hash du mot de passe admin (bcrypt)
ADMIN_PASSWORD_HASH=$2b$12$...
# Secret pour les sessions admin
ADMIN_SESSION_SECRET=minimum-32-caractères-aléatoires

# --- Email (Brevo/Sendinblue) ---
# Clé API Brevo pour les emails
BREVO_API_KEY=xkeysib-...
# Email expéditeur
BREVO_SENDER_EMAIL=contact@oradia.fr
# Nom expéditeur
BREVO_SENDER_NAME=Oradia

# --- Sécurité ---
# Secret pour les tokens JWT (minimum 32 caractères)
JWT_SECRET=votre-secret-jwt-sécurisé-32-caractères-minimum
# URL de votre site (pour les CORS)
SITE_URL=https://oradia.fr

# --- Configuration générale ---
# Environnement: development, staging, production
NODE_ENV=production
# Fuseau horaire par défaut
TIMEZONE=Europe/Paris

# ===========================================
# NOTES IMPORTANTES
# ===========================================

# 1. Ne JAMAIS exposer les clés secrètes côté client
#    - STRIPE_SECRET_KEY
#    - SUPABASE_SERVICE_ROLE_KEY
#    - MONDIAL_RELAY_PRIVATE_KEY
#    - MONDIAL_RELAY_API2_PASSWORD
#    - ADMIN_PASSWORD_HASH
#    - ADMIN_SESSION_SECRET
#    - JWT_SECRET
#    - BREVO_API_KEY

# 2. Les clés publiques peuvent être exposées côté client:
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY

# 3. Pour Mondial Relay:
#    - Contactez Mondial Relay pour obtenir vos identifiants API
#    - L'API 1 est pour la recherche de points relais
#    - L'API 2 est pour la création d'étiquettes d'expédition
#    - Utilisez BDTEST pour les tests, BDLIVE pour la production

# 4. Sécurité:
#    - Utilisez des secrets longs et aléatoires
#    - Changez régulièrement les clés API
#    - Ne versionnez jamais ce fichier avec de vraies clés

# 5. Vercel:
#    - Ajoutez ces variables dans les settings d'environnement Vercel
#    - Les variables commençant par NEXT_PUBLIC_ sont accessibles côté client
